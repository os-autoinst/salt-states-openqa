{
  "id": 4,
  "type": "table",
  "title": "Packet loss between worker hosts and other hosts",
  "description": "Shows packet loss within the the QA network infrastructure.\n\nThe first hostname is a salt managed host. The second hostname is a host listed under `required_external_networks` in `workerconf.sls` in the pillars repository that is pinged from the source host. See https://gitlab.suse.de/suse/wiki/-/blob/main/qe_infrastructure.md for details about hosts.",
  "gridPos": {
    "x": 0,
    "y": 0,
    "h": 9,
    "w": 12
  },
  "fieldConfig": {
    "defaults": {
      "custom": {
        "align": "auto",
        "footer": {
          "reducers": []
        },
        "cellOptions": {
          "type": "auto"
        },
        "inspect": false
      },
      "mappings": [],
      "thresholds": {
        "mode": "absolute",
        "steps": [
          {
            "color": "green",
            "value": null
          },
          {
            "color": "red",
            "value": 80
          }
        ]
      },
      "color": {
        "mode": "thresholds"
      },
      "max": 100,
      "min": 0,
      "unit": "percent"
    },
    "overrides": []
  },
  "transformations": [
    {
      "id": "seriesToRows",
      "options": {}
    },
    {
      "id": "filterByValue",
      "options": {
        "filters": [
          {
            "fieldName": "Value",
            "config": {
              "id": "greater",
              "options": {
                "value": 0
              }
            }
          }
        ],
        "type": "include",
        "match": "any"
      }
    }
  ],
  "pluginVersion": "12.4.5",
  "targets": [
    {
      "alias": "$tag_host - $tag_url",
      "datasource": {
        "type": "influxdb",
        "uid": "000000001"
      },
      "groupBy": [
        {
          "params": [
            "$__interval"
          ],
          "type": "time"
        },
        {
          "params": [
            "url"
          ],
          "type": "tag"
        },
        {
          "params": [
            "host"
          ],
          "type": "tag"
        },
        {
          "params": [
            "null"
          ],
          "type": "fill"
        }
      ],
      "measurement": "ping",
      "orderByTime": "ASC",
      "policy": "default",
      "query": "SELECT mean(\"percent_packet_loss\") FROM \"ping\" WHERE (\"network\"::tag = 'external') AND $timeFilter GROUP BY time($__interval), \"url\", \"host\" fill(null)",
      "rawQuery": true,
      "refId": "A",
      "resultFormat": "time_series",
      "select": [
        [
          {
            "params": [
              "percent_packet_loss"
            ],
            "type": "field"
          },
          {
            "params": [],
            "type": "mean"
          }
        ]
      ],
      "tags": [
        {
          "key": "network::tag",
          "operator": "=",
          "value": "external"
        }
      ]
    }
  ],
  "datasource": {
    "type": "influxdb",
    "uid": "000000001"
  },
  "options": {
    "showHeader": true,
    "cellHeight": "sm",
    "frameIndex": 2
  }
}
