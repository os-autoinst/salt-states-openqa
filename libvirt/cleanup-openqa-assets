#!/bin/bash -e

[[ $(df --output=pcent "/var/lib/libvirt/images" | tail -1 | tr -dc '0-9') -gt 70 ]] || exit 0

USED=$(virsh list --all --name | while read -r vm; do
  if [ -n "$vm" ]; then
    virsh domblklist "$vm" --details --inactive
    sleep 0.2
  fi
done | awk '/file|block/{print $4}')

[[ -n "$USED" ]] || exit 0

# Enable nullglob to handle case where no .qcow2 files exist
shopt -s nullglob

for img in /var/lib/libvirt/images/*.qcow2; do
    [[ -e "$img" ]] && \
    ! echo "$USED" | grep -qFx "$img" && \
    ! fuser -s "$img" 2>/dev/null && \
    rm -f "$img"
done
