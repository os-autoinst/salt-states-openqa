[Unit]
Description=Mount DRBD device with libvirtd images
After=network.target
After=drbd-promote@r0.service
BindsTo=drbd-promote@r0.service
Before=libvirtd.service
Before=virtqemud.service
DefaultDependencies=No

[Mount]
What=/dev/drbd0
Where=/var/lib/libvirt/images
Type=btrfs
Options=defaults,subvol=libvirt

[Install]
WantedBy=multi-user.target
RequiredBy=virtqemud.socket
